# ====================================================================
# MANDATORY SECURITY BOUNDARIES
# ====================================================================
# Complete lock down of environments, credentials, keys, and tokens
.env
.env.*
*.env
credentials*
*-credentials
*secrets*
*.pem
*.key
*.token
*.cert
*.crt
*.p12

# Block local bash automation tools by default
*.sh
git-sync
check-repo-secrets

# EXPLICIT EXCEPTIONS: Allow only these verified operational scripts
!sync-github.sh
!check-repo-secrets.sh

# ====================================================================
# DEVELOPMENT & SYSTEM ARTIFACTS
# ====================================================================
# Node / Build Tooling caches (if used for modern frontend components)
node_modules/
.npm/
dist/
build/

# Linux/Ubuntu & OS system artifacts
.DS_Store
Thumbs.db
.directory
*~
*.swp
*.swo

# Local text editor & IDE workspaces
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ====================================================================
# PYTHON / VIRTUAL ENVIRONMENTS
# ====================================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
env/
